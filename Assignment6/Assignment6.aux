\@writefile{toc}{\contentsline {section}{\numberline {1}How to prove that $3\textsc  {SAT} \leq _{P} 3\textsc  {Color}$ and thus $3\textsc  {Color}$ is NP-complete?}{1}{section.1}\protected@file@percent }
\newlabel{fig:gadget-palette}{{1a}{1}{Palette gadget. The triangle forces $T,F,N$ to use three different colours, which we interpret as True, False, and Neutral}{figure.caption.1}{}}
\newlabel{sub@fig:gadget-palette}{{a}{1}{Palette gadget. The triangle forces $T,F,N$ to use three different colours, which we interpret as True, False, and Neutral}{figure.caption.1}{}}
\newlabel{fig:gadget-variable}{{1b}{1}{Variable gadget. $x_i$ and $\bar x_i$ are adjacent to each other and to $N$, so exactly one receives the colour of $T$ and the other that of $F$}{figure.caption.1}{}}
\newlabel{sub@fig:gadget-variable}{{b}{1}{Variable gadget. $x_i$ and $\bar x_i$ are adjacent to each other and to $N$, so exactly one receives the colour of $T$ and the other that of $F$}{figure.caption.1}{}}
\newlabel{fig:gadget-or}{{1c}{1}{Clause (OR) gadget for $(a\vee b\vee c)$. Two grey triangles compute $u=a\vee b$ and $o=u\vee c$. Dotted edges connect literals; $u,o$ link to $N$, and the red edge forces $o$ to be True}{figure.caption.1}{}}
\newlabel{sub@fig:gadget-or}{{c}{1}{Clause (OR) gadget for $(a\vee b\vee c)$. Two grey triangles compute $u=a\vee b$ and $o=u\vee c$. Dotted edges connect literals; $u,o$ link to $N$, and the red edge forces $o$ to be True}{figure.caption.1}{}}
