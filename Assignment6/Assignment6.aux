\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Reduction from $3\textsc  {Sat}$ to $3\textsc  {Color}$ for the formula $\phi =(x\vee \bar  y\vee z)\wedge (\bar  x\vee y\vee \bar  z)$. Palette vertices $T,F,N$ enforce the three colors; variable gadgets force a consistent truth assignment; clause gadgets (gray vertices) propagate the OR of literals and force the final output to be True via the red edges.}}{2}{figure.caption.6}\protected@file@percent }
\newlabel{fig:3color}{{2}{2}{Reduction from $3\textsc {Sat}$ to $3\textsc {Color}$ for the formula $\phi =(x\vee \bar y\vee z)\wedge (\bar x\vee y\vee \bar z)$. Palette vertices $T,F,N$ enforce the three colors; variable gadgets force a consistent truth assignment; clause gadgets (gray vertices) propagate the OR of literals and force the final output to be True via the red edges}{figure.caption.6}{}}
